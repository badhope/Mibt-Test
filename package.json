{
  "name": "mbti-test",
  "version": "3.2.0",
  "description": "人格星球探索 - 专业MBTI心理测评系统",
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js --fix",
    "lint:check": "eslint src --ext .js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "npm run lint:check && npm run test",
    "sw:update": "echo 'Service Worker version updated'",
    "clean": "rm -rf node_modules dist",
    "prepare": "npx playwright install --with-deps"
  },
  "keywords": [
    "mbti",
    "personality-test",
    "psychology",
    "career-test",
    "personality-assessment"
  ],
  "author": "BadHope",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "terser": "^5.46.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/Mbti-Test.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/Mbti-Test/issues"
  },
  "homepage": "https://github.com/badhope/Mbti-Test#readme",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
